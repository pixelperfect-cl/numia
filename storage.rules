rules_version = '2';

// Firebase Storage Security Rules for Numia v1.0
service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to validate image file
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 2 * 1024 * 1024; // Max 2MB
    }

    // Entity logos: entities/{userId}/{entityId}
    match /entities/{userId}/{allPaths=**} {
      // Allow read if authenticated (could be stricter if logos are private)
      allow read: if isAuthenticated();
      // Allow write ONLY if the path matches the user's ID
      allow write: if request.auth.uid == userId && isValidImage();
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
